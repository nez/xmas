;;; init-vars.el --- Essential Emacs variables for xmas

(defvar user-emacs-directory (expand-file-name "~/.emacs.d/"))
(defvar user-init-file (expand-file-name "~/.xmas/init.el"))
(defvar emacs-version "29.1")
(defvar emacs-major-version 29)
(defvar system-type 'gnu/linux)
(defvar inhibit-startup-screen t)
(defvar noninteractive nil)
(defvar load-prefer-newer t)
(defvar major-mode 'fundamental-mode)
(defvar mode-name "Fundamental")
(defvar lexical-binding nil)
(defvar auto-mode-alist nil)
